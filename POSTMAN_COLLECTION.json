            "url": {
              "raw": "{{baseUrl}}/bookings/cancel/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "cancel", "{{bookingId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Product Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": {\n    \"name\": \"John Doe\",\n    \"phone\": \"9876543210\",\n    \"email\": \"john@example.com\",\n    \"street\": \"123 Main St\",\n    \"apartment\": \"Apt 4B\",\n    \"city\": \"Jaipur\",\n    \"district\": \"Jaipur\",\n    \"state\": \"Rajasthan\",\n    \"pincode\": \"302001\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payment/product-order",
              "host": ["{{baseUrl}}"],
              "path": ["payment", "product-order"]
            }
          }
        },
        {
          "name": "Create Booking Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"villaId\": \"{{roomId}}\",\n  \"checkIn\": \"2024-12-25\",\n  \"checkOut\": \"2024-12-27\",\n  \"guests\": 2,\n  \"guestDetails\": [\n    { \"name\": \"John Doe\", \"age\": 30, \"gender\": \"male\" },\n    { \"name\": \"Jane Doe\", \"age\": 28, \"gender\": \"female\" }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payment/booking-order",
              "host": ["{{baseUrl}}"],
              "path": ["payment", "booking-order"]
            }
          }
        },
        {
          "name": "Verify Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razorpay_order_id\": \"order_xxxxxxxxx\",\n  \"razorpay_payment_id\": \"pay_xxxxxxxxx\",\n  \"razorpay_signature\": \"signature_string\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payment/verify-payment",
              "host": ["{{baseUrl}}"],
              "path": ["payment", "verify-payment"]
            }
          }
        },
        {
          "name": "Mark Payment Failed",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razorpay_order_id\": \"order_xxxxxxxxx\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payment/payment-failed",
              "host": ["{{baseUrl}}"],
              "path": ["payment", "payment-failed"]
            }
          }
        }
      ]
    },
